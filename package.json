{
  "name": "aura-4k",
  "version": "2.5.0",
  "description": "Game Launcher with cinematic UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write js/",
    "build": "rollup -c",
    "build:prod": "rollup -c --environment BUILD:production",
    "build:all": "npm run lint && npm run test && npm run build"
  },
  "keywords": ["game-launcher", "electron", "retro-gaming"],
  "author": "AURA",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "rollup": "^4.13.0",
    "vitest": "^1.4.0"
  }
}